# App
APP_NAME=go-clean-template-portfolio
APP_VERSION=1.0.0

# HTTP
HTTP_PORT=8080
HTTP_USE_PREFORK_MODE=false

# Logger
LOG_LEVEL=debug

# Postgres
PG_POOL_MAX=2
PG_URL=postgres://user:password@localhost:5432/db

# gRPC
GRPC_PORT=8081

# RabbitMQ (AMQP RPC)
RMQ_RPC_SERVER=rpc_server
RMQ_RPC_CLIENT=rpc_client
RMQ_URL=amqp://guest:guest@localhost:5672/

# NATS RPC
NATS_RPC_SERVER=rpc_server
NATS_URL=nats://guest:guest@localhost:4222/